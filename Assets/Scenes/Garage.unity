      m_Calls: []
  m_text: "02/09/1997\n\tNo more fighting for me. I maintain gear for those who still
    can. \n\tI repair weapons, armors, backpacks, you name it. Use what I can from
    their scavenge missions, salvage the rest.\n\n\tHope they find some antibiotics
    soon, I am almost out.\n\n\tI can't become one of... them..."
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 6cf58e1c0760fb5498d8b9fbdc006a31, type: 2}
